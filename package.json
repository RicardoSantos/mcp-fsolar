{
  "name": "fsolar-mcp",
  "version": "1.0.21",
  "description": "Felicity Solar battery MCP server + REST API — exposes live battery data to Claude Code and any MCP client",
  "type": "commonjs",
  "main": "index.js",
  "types": "index.d.ts",
  "bin": {
    "fsolar-mcp": "server.js"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "server.js",
    "probe.js",
    "src/",
    "docs/",
    ".env.example",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node server.js",
    "probe": "node probe.js",
    "test": "node --test test/cache.test.js test/snapshot.test.js test/transform.test.js test/client.test.js test/errors.test.js test/logger.test.js test/helpers.test.js test/middleware.test.js test/compute.test.js test/hooks.test.js",
    "test:security": "node --test test/security.test.js",
    "setup": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0"
  },
  "keywords": [
    "felicity-solar",
    "battery",
    "mcp",
    "model-context-protocol",
    "claude",
    "solar",
    "bms",
    "iot"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RicardoSantos/mcp-fsolar.git"
  },
  "homepage": "https://github.com/RicardoSantos/mcp-fsolar#readme",
  "bugs": {
    "url": "https://github.com/RicardoSantos/mcp-fsolar/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=18"
  }
}
